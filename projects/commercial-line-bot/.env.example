# LINE Bot Configuration
LINE_CHANNEL_ACCESS_TOKEN=your_line_access_token_here
LINE_CHANNEL_SECRET=your_line_secret_here

# Notion Configuration (Production Runtime)
NOTION_TOKEN=your_notion_token_here
NOTION_MAIN_DB_ID=your_main_db_id_here
NOTION_ROUNDS_DB_ID=your_rounds_db_id_here
NOTION_QUESTION_BANK_DB_ID=your_question_bank_db_id_here

# Claude AI Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Initialization (scripts/init.js only)
# Only needed when running scripts/init.js to create databases
PARENT_PAGE_ID=your_parent_page_id_here

# Additional Database IDs (for test scripts and weekly review)
# WEEKLY_DB_ID is optional - only needed for weekly review functionality
WEEKLY_DB_ID=your_weekly_db_id_here

# Aliases for test scripts (can use same values as above)
MAIN_DB_ID=your_main_db_id_here
ROUNDS_DB_ID=your_rounds_db_id_here
QUESTION_BANK_DB_ID=your_question_bank_db_id_here

# Knowledge Management Databases
NOTION_KNOWLEDGE_DB_ID=your_knowledge_db_id_here
NOTION_TOPIC_SUMMARY_DB_ID=your_topic_summary_db_id_here

