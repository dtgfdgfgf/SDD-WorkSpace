## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options
.vs/
.vscode/

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# JetBrains Rider
.idea/
*.sln.iml

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/

# Test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Entity Framework Migrations (keep migrations folder itself)
# **/Migrations/*.cs
# **/Migrations/*.Designer.cs

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
logs/

# OS specific
.DS_Store
Thumbs.db

# SQL Server files
*.mdf
*.ldf
*.ndf

# Others
*.cache
*.swp
*.tmp
