{
  // ========================================
  // SDD Studio - VS Code Workspace Settings
  // ========================================

  // === Editor Settings ===
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.rulers": [100],
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,

  // === File Associations ===
  "files.associations": {
    "*.agent.md": "markdown",
    "*.prompt.md": "markdown",
    "constitution.md": "markdown",
    "spec.md": "markdown",
    "plan.md": "markdown",
    "tasks.md": "markdown",
    "learnings.md": "markdown",
    "retrospective.md": "markdown"
  },

  // === Search Exclusions ===
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/archive": true,
    "**/.git": true,
    "**/coverage": true,
    "**/*.min.js": true,
    "**/*.min.css": true
  },

  // === File Exclusions (Explorer) ===
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },

  // === Markdown Settings ===
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": false,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": false
    }
  },

  // === markdownlint Configuration ===
  // 停用所有 .md 檔案的 markdownlint 檢查
  "markdownlint.ignore": ["**/*.md"],

  // === Code Spell Checker Configuration ===
  "cSpell.enabled": true,
  "cSpell.words": ["speckit", "SDD", "NFR", "chatagent", "handoffs"],
  "cSpell.languageSettings": [
    {
      "languageId": "markdown",
      "enabled": false
    }
  ],
  "cSpell.ignorePaths": [
    "**/.github/**",
    "**/studio/**",
    "**/projects/duotify-*/**",
    "**/archive/**",
    "**/node_modules/**",
    "**/.git/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**"
  ],

  // === PowerShell Settings ===
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },

  // === Git Settings ===
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,

  // === Terminal Settings ===
  "terminal.integrated.defaultProfile.windows": "PowerShell",

  // === Explorer Settings ===
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.sortOrder": "type",

  // === GitHub Copilot Settings ===
  "github.copilot.enable": {
    "*": true,
    "markdown": true,
    "plaintext": true,
    "yaml": true,
    "json": true
  },

  // === VS Code 1.107+ Agent & Chat Settings (SDD Optimized) ===

  // [1] Custom Agents 可被主 Agent 自動呼叫為 Subagent
  // SDD 用途：讓你的 .github/agents/ 中的 custom agents 可以被自動委派處理特定 SDD 階段任務
  "chat.customAgentInSubagent.enabled": true,

  // [2] Background Agents 支援 Custom Agents
  // SDD 用途：讓 SDD 專用 agents 可以在背景自主執行長時間任務（如 analyze 階段的跨文件檢查）
  "github.copilot.chat.cli.customAgents.enabled": true,

  // [4] 摺疊 Agent 的 Tool Calls 輸出
  // SDD 用途：analyze/implement 階段時，agent 執行大量工具呼叫，摺疊後對話更清晰
  // 可選值：off（不摺疊）、withThinking（配合 thinking 摺疊）、always（總是摺疊）
  "chat.agent.thinking.collapsedTools": "always",

  // [5] 啟用 Agent Sessions 整合視圖
  // SDD 用途：在 Chat view 中直接管理所有 agent sessions，方便追蹤不同 feature 的進度
  "chat.viewSessions.enabled": true,

  // [6] 啟用新版 Inline Chat（優化為單檔編輯）
  // SDD 用途：implement 階段的快速程式碼修改更順暢，複雜任務自動升級到 Chat view
  "inlineChat.enableV2": true,

  // [7] 重啟後自動恢復上一個 Chat Session
  // SDD 用途：保持 SDD 工作脈絡，避免重啟後遺失對話歷史
  "chat.viewRestorePreviousSession": true,

  // [8] 啟用 GitHub MCP Server（內建）
  // SDD 用途：直接在 chat 中查詢 GitHub issues/PRs，方便追蹤需求來源
  "github.copilot.chat.githubMcpServer.enabled": true,

  // === File Nesting (Optional - cleaner view) ===
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "spec.md": "plan.md, tasks.md",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml",
    "*.ts": "${capture}.js, ${capture}.d.ts, ${capture}.js.map",
    "README.md": "README-*.md, CHANGELOG.md, LICENSE*"
  },
  "chat.useAgentSkills": true,
  "chat.tools.terminal.autoApprove": {
    "/^\\.\\\\studio\\\\scripts\\\\powershell\\\\init-project\\.ps1 -Name \"japanese-learning\" -Type Internal -Description \"LINE Bot 日語學習助教 - 手動入庫 \\+ LLM 路由 \\+ 單字文法練習\"$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^\\$projects = @\\(\n    @\\{ name = \"studio-automation\"; path = \"projects/studio-automation\" \\},\n    @\\{ name = \"japanese-learning\"; path = \"projects/japanese-learning\" \\}\n\\)\n\nforeach \\(\\$proj in \\$projects\\) \\{\n    \\$wsFile = Join-Path \\$proj\\.path \"\\$\\(\\$proj\\.name\\)\\.code-workspace\"\n    if \\(Test-Path \\$wsFile\\) \\{\n        \\$content = @\\{\n            folders = @\\(\n                @\\{ name = \\$proj\\.name; path = \"\\.\" \\},\n                @\\{ name = \"studio \\(read-only\\)\"; path = \"\\.\\./\\.\\./studio\" \\},\n                @\\{ name = \"agents \\(read-only\\)\"; path = \"\\.\\./\\.\\./\\.github/agents\" \\}\n            \\)\n            settings = @\\{\n                \"files\\.readonlyInclude\" = @\\{\n                    \"\\*\\*/studio/\\*\\*\" = \\$true\n                    \"\\*\\*/\\.github/agents/\\*\\*\" = \\$true\n                \\}\n            \\}\n        \\} \\| ConvertTo-Json -Depth 4\n        Set-Content -Path \\$wsFile -Value \\$content -Encoding UTF8\n        Write-Host \"Fixed: \\$wsFile\" -ForegroundColor Green\n    \\}\n\\}$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^Get-ChildItem -Path \"projects\", \"learning\" -Recurse -Filter \"\\*\\.code-workspace\" \\| ForEach-Object \\{\n    \\$name = \\$_\\.BaseName\n    \\$content = @\\{\n        folders = @\\(\n            @\\{ name = \\$name; path = \"\\.\" \\},\n            @\\{ name = \"studio \\(read-only\\)\"; path = \"\\.\\./\\.\\./studio\" \\},\n            @\\{ name = \"agents \\(read-only\\)\"; path = \"\\.\\./\\.\\./\\.github/agents\" \\}\n        \\)\n        settings = @\\{\n            \"files\\.readonlyInclude\" = @\\{\n                \"\\*\\*/studio/\\*\\*\" = \\$true\n                \"\\*\\*/\\.github/agents/\\*\\*\" = \\$true\n            \\}\n        \\}\n    \\} \\| ConvertTo-Json -Depth 4\n    Set-Content -Path \\$_\\.FullName -Value \\$content -Encoding UTF8\n    Write-Host \"Fixed: \\$\\(\\$_\\.FullName\\)\" -ForegroundColor Green\n\\}$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^# 驗證 junction 是否建立成功\nGet-ChildItem -Path \"projects/\\*/`\\.github/agents\", \"learning/\\*/`\\.github/agents\" -ErrorAction SilentlyContinue \\| ForEach-Object \\{\n    \\$item = Get-Item \\$_\\.FullName\n    if \\(\\$item\\.Attributes -band \\[IO\\.FileAttributes\\]::ReparsePoint\\) \\{\n        Write-Host \"✓ Junction: \\$\\(\\$_\\.FullName\\)\" -ForegroundColor Green\n    \\} else \\{\n        Write-Host \"✗ Not a junction: \\$\\(\\$_\\.FullName\\)\" -ForegroundColor Red\n    \\}\n\\}$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^Get-ChildItem -Path \"projects\", \"learning\" -Directory \\| ForEach-Object \\{\n    \\$agentsPath = Join-Path \\$_\\.FullName \"\\.github\\\\agents\"\n    if \\(Test-Path \\$agentsPath\\) \\{\n        \\$item = Get-Item \\$agentsPath\n        \\$isJunction = \\$item\\.Attributes -band \\[IO\\.FileAttributes\\]::ReparsePoint\n        if \\(\\$isJunction\\) \\{\n            Write-Host \"OK Junction: \\$\\(\\$_\\.Name\\)/\\.github/agents\" -ForegroundColor Green\n        \\} else \\{\n            Write-Host \"NOT Junction: \\$\\(\\$_\\.Name\\)/\\.github/agents\" -ForegroundColor Yellow\n        \\}\n    \\} else \\{\n        Write-Host \"MISSING: \\$\\(\\$_\\.Name\\)/\\.github/agents\" -ForegroundColor Red\n    \\}\n\\}$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
